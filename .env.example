# ── College Admission Chatbot — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# OpenAI API Key (optional)
# If not set, the chatbot runs in fallback mode (no API needed — great for demos)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ChromaDB storage path (optional — defaults to ./chroma_db)
CHROMA_PERSIST_DIR=./chroma_db

# FastAPI server URL — used by frontend when USE_DIRECT=False
API_URL=http://localhost:8000
